# Client (exposed to browser — public only)
VITE_APP_NAME=ChatGPT Archive

# Public site URL (production). Used for the canonical link in index.html; committed in `.env.production` as https://memodee.app
# VITE_SITE_URL=https://memodee.app

# Umami analytics (production). Injected only when `import.meta.env.PROD` is true.
# Use the website ID from your Umami project (Memodee).
VITE_UMAMI_WEBSITE_ID=0e8e2993-5f47-477c-b6a0-1a9b1fb70f00

# Server (Vercel serverless — never exposed to client)
# Notion token is passed per-request from client to proxy,
# stored only in the user's localStorage.
